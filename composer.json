{
    "name": "isapp/laravel-forge-mcp",
    "description": "Native Laravel MCP server for managing Laravel Forge servers, sites and deployments via the Forge API v2.",
    "keywords": ["laravel", "mcp", "forge", "deployment", "ai"],
    "homepage": "https://github.com/isap-ou/laravel-forge-mcp",
    "license": "MIT",
    "authors": [
        {
            "name": "Andrii Trush",
            "email": "andrii.trush@isapp.be"
        }
    ],
    "support": {
        "issues": "https://github.com/isap-ou/laravel-forge-mcp/issues",
        "source": "https://github.com/isap-ou/laravel-forge-mcp"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/forge-sdk": "^4.0",
        "laravel/mcp": "^0.7"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Isapp\\LaravelForgeMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Isapp\\LaravelForgeMcp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "lint:test": "vendor/bin/pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Isapp\\LaravelForgeMcp\\ForgeMcpServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
